# Local development env. Copy to .env (which is gitignored) and fill in
# the real values. `dotenvx encrypt` will encrypt every value in place
# and write the decryption key to .env.keys (also gitignored). After
# encrypting, run the app with:
#
#     dotenvx run -- bundle exec rackup -p 9292 -o 127.0.0.1
#
# Production deployments should set these as plain environment vars on
# the container — dotenvx is dev-only.

# At-rest encryption keys for ActiveRecord::Encryption. If unset on
# first boot, gasmoney generates them and persists to db/encryption.key
# (mode 0600). Setting them here makes the encrypted DB portable across
# hosts.
GASMONEY_ENCRYPTION_KEY="change-me-32-or-more-random-chars"
GASMONEY_DETERMINISTIC_KEY="change-me-32-or-more-random-chars"
GASMONEY_KEY_DERIVATION_SALT="change-me-32-or-more-random-chars"

# FlareSolverr instance URL. Leaving this unset disables the auto-sync
# feature. The UI accepts a URL too — if both are set, the UI value
# wins.
FLARESOLVERR_URL="http://localhost:8191"

# GasBuddy credentials, used only for local-development testing of the
# sync code. Production stores credentials encrypted in the DB via the
# /sync UI.
GASBUDDY_USERNAME=""
GASBUDDY_PASSWORD=""
