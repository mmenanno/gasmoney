.DS_Store
**/.DS_Store

# Ruby / Bundler
/.bundle/
/vendor/bundle/
*.gem
*.rbc

# SQLite
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-wal
/db/*.sqlite3-shm
/state/*.sqlite3
/state/*.sqlite3-*

# At-rest encryption master keys. Auto-generated on first boot if env
# vars aren't supplied; losing this file makes encrypted credentials
# unrecoverable, so back it up alongside the SQLite DB.
/db/encryption.key
/state/encryption.key

# Logs / tmp
/log/
/tmp/
*.log

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Env. dotenvx encrypts the contents of .env in place; .env.keys holds
# the decryption key. Both stay out of git — `.env.example` (committed)
# documents the variable list.
.env
.env.local
.env.keys
.envrc

# Personal fuel logs — never commit your own GasBuddy exports
/exported_logs/

# Generated icon assets — built from app/assets/icon.svg via bin/build-icons
/app/assets/icons/icon-128.png
/app/assets/icons/icon-256.png
/app/assets/icons/icon-512.png

# Test runner caches
/coverage/
.byebug_history

# Playwright MCP scratch dir (accessibility-tree snapshots and screenshots
# from interactive testing sessions)
/.playwright-mcp/
