<% linked_count = GasMoney::Vehicle.where.not(gasbuddy_uuid: nil).count
   synced_fillups = GasMoney::Fillup.where.not(gasbuddy_entry_uuid: nil).count %>

<section class="sync-status">
  <div class="sync-status__head">
    <h2 class="section-heading">GasBuddy auto-sync</h2>
    <form action="/sync/run" method="post" class="inline-form">
      <button type="submit" class="btn btn--primary"
              <%= "disabled" unless @setting.credentials_present? %>>
        Sync now
      </button>
    </form>
  </div>

  <div class="sync-status__readouts">
    <div class="readout">
      <div class="readout__value"><%= @setting.last_sync_at ? fmt_relative(@setting.last_sync_at) : "—" %></div>
      <div class="readout__caption">last run</div>
    </div>
    <div class="readout">
      <div class="readout__value"><%= linked_count %></div>
      <div class="readout__caption">linked vehicles</div>
    </div>
    <div class="readout">
      <div class="readout__value"><%= synced_fillups %></div>
      <div class="readout__caption">synced fillups</div>
    </div>
  </div>

  <form action="/sync/auto" method="post" class="auto-toggle">
    <input type="hidden" name="auto_sync_enabled" value="<%= @setting.auto_sync_enabled ? '0' : '1' %>">
    <button type="submit" class="pin-toggle <%= 'pin-toggle--on' if @setting.auto_sync_enabled %>">
      <%= @setting.auto_sync_enabled ? "★ auto-sync on (00:00 UTC daily)" : "☆ auto-sync off" %>
    </button>
  </form>
</section>

<section class="form-section">
  <h3 class="section-heading">GasBuddy account</h3>
  <% if @setting.credentials_present? %>
    <p class="lede">
      Connected as <strong class="link-accent"><%= h(@setting.username) %></strong>.
      Stored encrypted at rest.
    </p>
    <form action="/sync/credentials/clear" method="post" class="inline-form"
          data-confirm="Clear stored GasBuddy credentials? You'll need to re-enter them to sync again."
          data-confirm-action="Clear credentials"
          data-confirm-tone="danger">
      <button type="submit" class="btn btn--ghost">Clear credentials</button>
    </form>
  <% else %>
    <p class="lede">Used to log in to GasBuddy from the bundled headless Chromium. Stored encrypted at rest.</p>
    <form action="/sync/credentials" method="post" class="form">
      <label class="field">
        <span class="field__label">Username or email</span>
        <input type="text" name="username" autocomplete="off" required>
      </label>
      <label class="field">
        <span class="field__label">Password</span>
        <input type="password" name="password" autocomplete="new-password" required>
      </label>
      <button type="submit" class="btn btn--primary">Save credentials</button>
    </form>
  <% end %>
</section>

<section class="form-section">
  <div class="sync-status__head">
    <h3 class="section-heading">Vehicle linking</h3>
    <% if @setting.credentials_present? %>
      <form action="/sync/garage/refresh" method="post" class="inline-form">
        <button type="submit" class="btn btn--ghost btn--ghost-sm">Refresh garage</button>
      </form>
    <% end %>
  </div>
  <% active_remotes  = @remote_vehicles.reject(&:ignored) %>
  <% ignored_remotes = @remote_vehicles.select(&:ignored) %>
  <% if @remote_vehicles.empty? %>
    <p class="lede">
      No remote vehicle list yet —
      <% if @setting.credentials_present? %>
        click <strong>Refresh garage</strong> to fetch the list of vehicles on your GasBuddy account.
        Once loaded, link each remote vehicle to a local one (or set aside ones you don't care about) and run a sync.
      <% else %>
        save GasBuddy credentials first, then refresh the garage.
      <% end %>
    </p>
  <% else %>
    <p class="lede">Map each GasBuddy vehicle to a local one. Unlinked vehicles are skipped each sync; ignored vehicles are tucked out of the way and stay skipped.</p>
    <% if active_remotes.any? %>
      <table class="ledger ledger--linking">
        <thead>
          <tr>
            <th>GasBuddy vehicle</th>
            <th>Linked to</th>
          </tr>
        </thead>
        <tbody>
          <% active_remotes.each do |remote| %>
            <% linked = @local_vehicles.find { |v| v.gasbuddy_uuid == remote.uuid } %>
            <% current_value = linked ? linked.id.to_s : "" %>
            <% selected_label = linked ? linked.display_name : "— not linked —" %>
            <tr>
              <td><%= h(remote.display_name) %><br><span class="caption-mono"><%= h(remote.uuid) %></span></td>
              <td data-link-cell>
                <% if linked %>
                  <div class="link-summary" data-link-summary>
                    <span class="link-summary__arrow" aria-hidden="true">→</span>
                    <span class="link-summary__target"><%= h(linked.display_name) %></span>
                  </div>
                <% end %>
                <form action="/sync/vehicles/link" method="post"
                      class="inline-form inline-form--link"
                      data-link-form
                      <%= 'hidden' if linked %>>
                  <input type="hidden" name="remote_uuid" value="<%= h(remote.uuid) %>">
                  <div class="select" data-select>
                    <button type="button" class="select__button" aria-haspopup="listbox" aria-expanded="false">
                      <span class="select__value"><%= h(selected_label) %></span>
                      <span class="select__chevron" aria-hidden="true"></span>
                    </button>
                    <ul class="select__list" role="listbox" hidden>
                      <li class="select__option<%= ' select__option--selected' if current_value == '' %>" role="option" data-value="">— not linked —</li>
                      <% @local_vehicles.each do |v| %>
                        <li class="select__option<%= ' select__option--selected' if current_value == v.id.to_s %>" role="option" data-value="<%= v.id %>"><%= h(v.display_name) %></li>
                      <% end %>
                    </ul>
                    <input type="hidden" name="vehicle_id" value="<%= h(current_value) %>">
                  </div>
                  <button type="submit" class="btn btn--ghost btn--ghost-sm">save</button>
                </form>
                <% if linked %>
                  <button type="button" class="link-action" data-link-edit>change</button>
                <% end %>
                <form action="/sync/vehicles/ignore" method="post" class="inline-form inline-form--ignore"
                      data-confirm="Ignore <%= h(remote.display_name) %>? Sync will skip it permanently until you restore it."
                      data-confirm-action="Ignore"
                      data-confirm-tone="danger">
                  <input type="hidden" name="remote_uuid" value="<%= h(remote.uuid) %>">
                  <button type="submit" class="link-action" aria-label="Ignore <%= h(remote.display_name) %>">ignore</button>
                </form>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <% if ignored_remotes.any? %>
      <div class="ignored-remotes" aria-label="Ignored GasBuddy vehicles">
        <p class="ignored-remotes__heading">Ignored<span class="ignored-remotes__count"><%= ignored_remotes.size %></span></p>
        <ul class="ignored-remotes__list">
          <% ignored_remotes.each do |remote| %>
            <li class="ignored-remotes__item">
              <span class="ignored-remotes__name"><%= h(remote.display_name) %></span>
              <span class="ignored-remotes__uuid"><%= h(remote.uuid[0, 8]) %></span>
              <form action="/sync/vehicles/restore" method="post" class="inline-form">
                <input type="hidden" name="remote_uuid" value="<%= h(remote.uuid) %>">
                <button type="submit" class="link-action">restore</button>
              </form>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</section>

<section class="form-section sync-runs" data-sync-runs>
  <div class="sync-status__head">
    <h3 class="section-heading">Sync activity</h3>
    <% if @recent_runs.any? { |r| !r.running? } %>
      <form action="/sync/runs/clear" method="post" class="inline-form"
            data-confirm="Clear all finished sync runs and their log entries? Running syncs will be kept."
            data-confirm-action="Clear log"
            data-confirm-tone="danger">
        <button type="submit" class="btn btn--ghost btn--ghost-sm">Clear log</button>
      </form>
    <% end %>
  </div>
  <% if @recent_runs.empty? %>
    <p class="empty">No sync runs yet.</p>
  <% else %>
    <ol class="run-list">
      <% @recent_runs.each do |run| %>
        <li class="run run--<%= run.status %>" data-run-id="<%= run.id %>"
            <%= 'data-running="1"' if run.running? %>>
          <div class="run__rail" aria-hidden="true"></div>
          <div class="run__body">
            <div class="run__header">
              <span class="run__status status-pill status-pill--<%= run.status %>">
                <%= { "ok"=>"✓ OK", "failed"=>"✗ failed", "partial"=>"⚠ partial", "running"=>"↻ running" }[run.status] %>
              </span>
              <span class="run__time" data-since="<%= run.started_at %>"><%= fmt_relative(run.started_at) %></span>
              <span class="run__trigger"><%= run.trigger %></span>
              <% if run.duration_seconds %>
                <span class="run__duration"><%= run.duration_seconds %>s</span>
              <% end %>
            </div>
            <div class="run__counts" data-run-counts>
              <span class="count"><strong data-count="vehicles_synced"><%= run.vehicles_synced %></strong> vehicles</span>
              <span class="count"><strong data-count="fillups_inserted"><%= run.fillups_inserted %></strong> inserted</span>
              <span class="count"><strong data-count="fillups_linked"><%= run.fillups_linked %></strong> linked</span>
              <span class="count"><strong data-count="fillups_skipped"><%= run.fillups_skipped %></strong> skipped</span>
            </div>
            <% if run.error_message.to_s != "" %>
              <p class="run__error" data-run-error><%= h(run.error_message) %></p>
            <% end %>
            <details class="run__log">
              <summary><span data-log-count><%= run.sync_log_entries.size %></span> log entries</summary>
              <ol class="log-entries" data-log-entries>
                <% run.sync_log_entries.each do |entry| %>
                  <li class="log-entry log-entry--<%= entry.level %>">
                    <span class="log-entry__time"><%= entry.created_at[11, 8] rescue entry.created_at %></span>
                    <span class="log-entry__msg"><%= h(entry.message) %></span>
                    <% if entry.parsed_detail %>
                      <pre class="log-entry__detail"><%= h(JSON.pretty_generate(entry.parsed_detail)) %></pre>
                    <% end %>
                  </li>
                <% end %>
              </ol>
            </details>
          </div>
        </li>
      <% end %>
    </ol>
  <% end %>
</section>

<script src="/sync.js" defer></script>
