<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>Gas Money</title>

  <!-- PWA manifest + theming. theme-color paints the address bar / OS UI
       chrome when the app is installed; matches --bg from style.css so
       there's no seam at the top of the viewport. -->
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#101113">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Gas Money">
  <meta name="mobile-web-app-capable" content="yes">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" href="/icons/icon-256.png">

  <script src="/select.js" defer></script>
  <script src="/confirm.js" defer></script>
  <script src="/nav.js" defer></script>
  <script src="/link-edit.js" defer></script>
  <script src="/filepicker.js" defer></script>
  <script src="/pwa-refresh.js" defer></script>
  <script>
    // Service worker registration. The worker only caches the static
    // app shell — see public/sw.js for scope details. Failures are
    // logged but never block page rendering.
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", function () {
        navigator.serviceWorker.register("/sw.js").catch(function (err) {
          console.warn("[gasmoney] service worker registration failed:", err);
        });
      });
    }
  </script>
</head>
<body>
  <main class="page">
    <header class="topbar">
      <a href="/" class="brand">
        <img src="/favicon.svg" alt="" class="brand__mark" width="36" height="36">
        <span class="brand__name">Gas Money</span>
      </a>
      <button type="button" class="nav-toggle" aria-label="Toggle navigation"
              aria-expanded="false" aria-controls="primary-nav">
        <span class="nav-toggle__line" aria-hidden="true"></span>
        <span class="nav-toggle__line" aria-hidden="true"></span>
        <span class="nav-toggle__line" aria-hidden="true"></span>
      </button>
      <% nav_path = request.path_info.to_s %>
      <% nav_active = ->(prefix) { nav_path == prefix || nav_path.start_with?("#{prefix}/") } %>
      <nav class="nav" id="primary-nav">
        <a href="/vehicles"    class="nav-link<%= ' nav-link--active' if nav_active.call('/vehicles') %>">Vehicles</a>
        <a href="/saved_trips" class="nav-link<%= ' nav-link--active' if nav_active.call('/saved_trips') %>">Saved trips</a>
        <a href="/sync"        class="nav-link<%= ' nav-link--active' if nav_active.call('/sync') %>">Sync</a>
        <a href="/import"      class="nav-link<%= ' nav-link--active' if nav_active.call('/import') %>">Import logs</a>
      </nav>
    </header>

    <% if (msg = flash) %>
      <div class="flash flash--<%= h(msg[:kind]) %>"><%= h(msg[:message]) %></div>
    <% end %>

    <%= yield %>

    <footer class="footer">
      <span><a href="https://github.com/mmenanno/gasmoney" class="link-soft">github.com/mmenanno/gasmoney</a> · v<%= GasMoney::VERSION %></span>
      <button type="button" class="footer__refresh" data-pwa-refresh hidden>
        Refresh app
      </button>
    </footer>
  </main>
</body>
</html>
