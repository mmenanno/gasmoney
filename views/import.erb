<section class="form-section">
  <h3 class="section-heading">Import a GasBuddy CSV export</h3>
  <p class="lede">
    Pick the vehicle these logs belong to. Re-importing the same file is safe — duplicate fillups are skipped automatically.
  </p>

  <% if vehicles.any? %>
    <form action="/import" method="post" enctype="multipart/form-data" class="form">
      <div class="field">
        <span class="field__label">Vehicle</span>
        <div class="select" data-select>
          <button type="button" class="select__button" aria-haspopup="listbox" aria-expanded="false">
            <span class="select__value"><%= h(vehicles.first.display_name) %></span>
            <span class="select__chevron" aria-hidden="true"></span>
          </button>
          <ul class="select__list" role="listbox" hidden>
            <% vehicles.each_with_index do |v, i| %>
              <li class="select__option<%= ' select__option--selected' if i == 0 %>" role="option" data-value="<%= v.id %>"><%= h(v.display_name) %></li>
            <% end %>
          </ul>
          <input type="hidden" name="vehicle_id" value="<%= vehicles.first.id %>" required>
        </div>
      </div>
      <div class="field">
        <span class="field__label">CSV file</span>
        <label class="filepicker" data-filepicker>
          <input type="file" name="file" accept=".csv" required class="filepicker__input" data-filepicker-input>
          <span class="filepicker__action" aria-hidden="true">choose file</span>
          <span class="filepicker__name" data-filepicker-name>no file chosen</span>
          <span class="filepicker__dot" aria-hidden="true">·</span>
          <span class="filepicker__hint" aria-hidden="true">CSV</span>
        </label>
      </div>
      <button type="submit" class="btn btn--primary">Import</button>
    </form>
  <% else %>
    <p class="empty">Add a <a href="/vehicles" class="link-accent">vehicle</a> first.</p>
  <% end %>

</section>
